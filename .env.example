# Copy this file to .env and fill in the values.
# Everything works out-of-the-box with the defaults, only override if needed.

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ENDPOINT_LOCAL=http://localhost:9000
MINIO_BUCKET_BRONZE=tessera-bronze
MINIO_BUCKET_SILVER=tessera-silver
MINIO_BUCKET_GOLD=tessera-gold

# ---------- DuckDB ----------
DUCKDB_PATH=warehouse/tessera.duckdb

# ---------- Google Analytics 4 (optional, falls back to demo data) ----------
# If unset, the ingestion pipeline uses bundled GA4 demo data from the public
# Google Merchandise Store export. Set these to pull from your own GA4 property.
GA4_PROPERTY_ID=
GA4_CREDENTIALS_FILE=

# ---------- Meta Graph API (optional, falls back to synthetic Pixel events) ----------
# Meta does not expose production ads data without a Business account.
# The synthetic fallback produces events at the real Pixel schema.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ---------- Shopify (optional, falls back to sample dataset) ----------
# Uses a Shopify dev store if credentials are provided, otherwise the bundled
# sample dataset is used.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# ---------- Kestra ----------
KESTRA_URL=http://localhost:8080

# ---------- Streamlit ----------
STREAMLIT_SERVER_PORT=8501

# ---------- Pipeline behaviour ----------
# Number of days of data to generate/ingest
PIPELINE_LOOKBACK_DAYS=90
# Random seed for reproducible synthetic fallback
PIPELINE_SEED=42

# ---------- Observability ----------
# json   = structured one-object-per-line logs (production)
# pretty = colourised loguru output (default in dev)
TESSERA_LOG_FORMAT=pretty
TESSERA_LOG_LEVEL=INFO
# Optional: write a copy of every run audit row to this DuckDB file.
# Empty = audit table is created inside the main warehouse only.
TESSERA_AUDIT_DB=

# ---------- LocalStack / Terraform (optional) ----------
# Edge endpoint used by ingestion when it talks to S3 via LocalStack.
# Leave empty in normal MinIO mode.
LOCALSTACK_ENDPOINT=
